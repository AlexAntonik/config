{
  "[css]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[html]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[markdown]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[nix]": {
    "editor.defaultFormatter": "jnoortheen.nix-ide"
  },
  "[scss]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[sql]": {
    "editor.defaultFormatter": "inferrinizzard.prettier-sql-vscode"
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "bashIde.shellcheckPath": "shellcheck",
  "editor.cursorBlinking": "phase",
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.fontFamily": "'JetBrainsMono Nerd Font Mono', 'Fira Code', monospace",
  "editor.fontSize": 20,
  "editor.inlineSuggest.enabled": true,
  "editor.lineNumbers": "relative",
  "editor.minimap.enabled": false,
  "editor.guides.bracketPairs": true,
  "editor.guides.bracketPairsHorizontal": false,
  "explorer.confirmPasteNative": false,
  "extensions.autoCheckUpdates": false,
  "files.autoSave": "afterDelay",
  "git.autofetch": true,
  "git.confirmSync": false,
  "git.enableSmartCommit": true,
  "keyboard.dispatch": "keyCode",
  "nix.enableLanguageServer": true,
  "nix.hiddenLanguageServerErrors": ["textDocument/definition"],
  "nix.serverPath": "nixd",
  "nix.serverSettings": {
    "nil": {
      "formatting": {
        "command": ["nixfmt"]
      }
    },
    "nixd": {
      "formatting": {
        "command": ["nixfmt"]
      },
      "nixpkgs": {
        "expr": "import (builtins.getFlake \"~/config\").inputs.nixpkgs { }"
      }
    }
  },
  "shfmt.executablePath": "shfmt",
  "terminal.integrated.fontFamily": "'JetBrainsMono Nerd Font Mono', 'Fira Code', monospace",
  "terminal.integrated.fontLigatures.featureSettings": "\"liga\" on",
  "update.mode": "none",
  "vim.handleKeys": {
    "<Esc>": true
  },
  "vim.useCtrlKeys": true,
  "vim.useSystemClipboard": true,
  "window.controlsStyle": "hidden",
  "window.customTitleBarVisibility": "never",
  "workbench.editor.enablePreview": false,
  "workbench.editor.limit.enabled": true,
  "workbench.editor.limit.value": 5,
  "workbench.editor.showTabs": "single",
  "editor.wordWrap": "on",
  "vim.langmap": "ФИСВУΑПРШОЛДЬТЩЗЙКЫЕГМЦЧНЯ;ABCDEFGHIJKLMNOPQRSTUVWXYZ,фисвуапршолдьтщзйкыегмцчня;abcdefghijklmnopqrstuvwxyz",
  "github.copilot.enable": {
    "*": true,
    "plaintext": false,
    "markdown": false,
    "scminput": false,
    "go": true,
    "sql": true,
    "dockercompose": true
  },
  "workbench.colorCustomizations": {
    "editor.background": "#090909",
    "titleBar.activeBackground": "#090909",
    "titleBar.inactiveBackground": "#090909",
    "statusBar.background": "#090909",
    "activityBar.background": "#090909",
    "sideBarSectionHeader.background": "#090909",
    "sideBar.background": "#090909",
    "sideBar.border": "#090909",
    "editorGroupHeader.tabsBackground": "#090909",
    "tab.inactiveBackground": "#090909",
    "scrollbar.shadow": "#090909",
    "statusBar.debuggingBackground": "#090909",
    "statusBar.noFolderBackground": "#090909",
    "menu.background": "#090909",
    "panel.border": "#090909",
    "tab.activeBorder": "#007acc",
    "tab.hoverBorder": "#007acc",
    "sash.hoverBorder": "#09090900",
    "focusBorder": "#09090900",
    "input.border": "#09090900",
    "widget.shadow": "#09090900",
    "editorOverviewRuler.border": "#09090900",
    "sideBarSectionHeader.border": "#09090900",
    "tab.border": "#09090900",
    "debugToolBar.background": "#090909",
    "editorWidget.background": "#090909",
    "list.inactiveSelectionBackground": "#37373d",
    "list.activeSelectionBackground": "#373730",
    "list.focusBackground": "#373730",
    "list.hoverBackground": "#373730",
    "statusBar.focusBorder": "#090909",
    "editorInlayHint.background": "#09090900",
    "editorStickyScroll.border": "#111112",
    "editorStickyScroll.shadow": "#111112"
  },
  "terminal.integrated.fontSize": 18,
  "workbench.colorTheme": "Dark+",
  "go.toolsManagement.autoUpdate": true,
  "go.inlayHints.assignVariableTypes": true,
  "go.inlayHints.compositeLiteralFields": true,
  "go.inlayHints.compositeLiteralTypes": true,
  "go.inlayHints.constantValues": true,
  "go.inlayHints.functionTypeParameters": true,
  "go.inlayHints.ignoredError": true,
  "go.inlayHints.parameterNames": true,
  "go.inlayHints.rangeVariableTypes": true,
  "chat.viewSessions.enabled": false,
  "workbench.browser.searchEngine": "google",
  "gitlens.ai.model": "vscode",
  "gitlens.ai.vscode.model": "copilot:gpt-4o-mini",
  "workbench.activityBar.location": "hidden"
}
